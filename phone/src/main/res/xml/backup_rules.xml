<?xml version="1.0" encoding="utf-8"?>
<!-- Auto Backup rules (API 30 and below). Recorded activity sessions under
     filesDir/activities are full GPS track histories — a movement diary of
     the user's rides and runs (threat T-03-01). Never ship them to cloud
     backups (WR-06). -->
<full-backup-content>
    <exclude domain="file" path="activities/" />
    <!-- Strava OAuth tokens: Keystore master key never leaves the device — a
         restored copy is undecryptable ciphertext (AEADBadTagException).
         03-RESEARCH Pitfall 2. -->
    <exclude domain="sharedpref" path="strava_auth.xml" />
</full-backup-content>
